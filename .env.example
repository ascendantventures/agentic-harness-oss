# Anthropic
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...   # OR use ANTHROPIC_API_KEY
# ANTHROPIC_API_KEY=sk-ant-api03-...

# GitHub — the repo where issues live and pipeline state is tracked
GITHUB_REPO=owner/repo

# Webhook secret (if using GitHub webhook to trigger factory runs)
FACTORY_SECRET=your-webhook-secret

# App base URL (your deployed factory app, for clone-token and deliver-pr endpoints)
FACTORY_APP_URL=https://your-app.vercel.app

# Factory runtime (optional)
# FACTORY_LOG=/tmp/factory-loop.log
# FACTORY_USE_CLAUDE=1

# Binary paths (optional — defaults to PATH lookup)
# CLAUDE_BIN=claude
# OPENCLAW_BIN=openclaw

# Vercel deployment (optional)
# VERCEL_TOKEN=your-vercel-token

# Notifications (optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Supabase (optional — for project/submission tracking and storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
